{
  "name": "markdown-it-anx",
  "version": "1.0.0",
  "description": "Markdown-it plugin for ANX rules",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "start": "node examples/demo.js",
    "build": "rollup -c",
    "dev": "rollup -c -w"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "express": "^4.19.2",
    "rollup": "^4.12.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3"
  },
  "keywords": [
    "markdown-it",
    "markdown-it-plugin",
    "anx"
  ],
  "author": "",
  "license": "MIT"
}